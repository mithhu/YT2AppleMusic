{
  "manifest_version": 3,
  "name": "YT2AppleMusic - YouTube to Apple Music",
  "version": "2.0.3",
  "description": "Instantly jump from YouTube music videos to Apple Music app",

  "permissions": ["activeTab", "storage", "tabs"],

  "host_permissions": [
    "https://www.youtube.com/*",
    "https://music.apple.com/*",
    "https://embed.music.apple.com/*",
    "https://itunes.apple.com/*",
    "https://*.supabase.co/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content-youtube.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "YT2AppleMusic - YouTube to Apple Music",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["apple-music-player.html", "confirmation.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
